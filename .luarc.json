{
  "$schema": "https://www.schemastore.org/stylua.json",
  "runtime": {
    "version": "Lua 5.3"
  },
  "workspace": {
    "library": ["lua_types"],
    "checkThirdParty": false
  },
  "diagnostics": {
    "globals": ["globals", "luajava"],
    "disable": ["lowercase-global"]
  },
  "hint": {
    "enable": true,
    "arrayIndex": "Enable",
    "setType": true,
    "paramName": "All"
  }
}
