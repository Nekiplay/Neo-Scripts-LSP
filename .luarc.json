{
  "$schema": "https://raw.githubusercontent.com/LuaLS/lua-language-server/master/resource/schema.json",
  "workspace": {
    "library": ["lua_types"],
    "checkThirdParty": false
  },
  "diagnostics": {
    "disable": ["lowercase-global"]
  },
  "runtime": {
    "version": "Lua 5.2"
  },
  "hint": {
    "enable": true,
    "arrayIndex": "Enable",
    "setType": true,
    "paramName": "All"
  }
}
